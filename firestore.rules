rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidJourney() {
      return request.resource.data.keys().hasAll(['driverName', 'from', 'to', 'departureTime', 'availableSeats', 'driverPhone'])
        && request.resource.data.driverName is string
        && request.resource.data.from is string
        && request.resource.data.to is string
        && request.resource.data.driverPhone is string
        && request.resource.data.availableSeats is int
        && request.resource.data.availableSeats > 0
        && request.resource.data.availableSeats <= 8;
    }

    function isCancelUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled'
        && resource.data.status == 'active';
    }

    function isValidEdit() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['availableSeats', 'departureTime'])
        && request.resource.data.availableSeats is int
        && request.resource.data.availableSeats > 0
        && request.resource.data.availableSeats <= 8
        && resource.data.status == 'active';
    }

    match /journeys/{journeyId} {
      allow read: if true;
      allow create: if isValidJourney();
      allow update: if isCancelUpdate() || isValidEdit();
      allow delete: if false;
    }

    function isValidRequest() {
      return request.resource.data.keys().hasAll(['passengerName', 'from', 'to', 'departureTime', 'seatsNeeded', 'passengerPhone'])
        && request.resource.data.passengerName is string
        && request.resource.data.from is string
        && request.resource.data.to is string
        && request.resource.data.passengerPhone is string
        && request.resource.data.seatsNeeded is int
        && request.resource.data.seatsNeeded > 0
        && request.resource.data.seatsNeeded <= 8;
    }

    function isCancelRequestUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled'
        && resource.data.status == 'active';
    }

    function isValidRequestEdit() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['seatsNeeded', 'departureTime'])
        && request.resource.data.seatsNeeded is int
        && request.resource.data.seatsNeeded > 0
        && request.resource.data.seatsNeeded <= 8
        && resource.data.status == 'active';
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isValidRequest();
      allow update: if isCancelRequestUpdate() || isValidRequestEdit();
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasAll(['journeyId', 'reason'])
        && request.resource.data.journeyId is string
        && request.resource.data.reason is string;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
