rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isValidJourney() {
      return request.resource.data.keys().hasAll(['driverId', 'from', 'to', 'date', 'seats', 'driverPhone'])
        && request.resource.data.driverPhone is string
        && request.resource.data.driverPhone.matches('[+]?[0-9\\s\\-\\(\\)]{10,15}')
        && request.resource.data.seats is int
        && request.resource.data.seats > 0
        && request.resource.data.seats <= 8;
    }

    function isValidMessage() {
      return request.resource.data.keys().hasAll(['senderId', 'receiverId', 'journeyId', 'content', 'timestamp'])
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 1000;
    }

    // Journeys collection - drivers post journeys
    match /journeys/{journeyId} {
      // Allow anyone to read journeys (for browsing)
      allow read: if true;

      // Only authenticated users can create journeys
      allow create: if isAuthenticated()
        && isValidJourney()
        && request.resource.data.driverId == request.auth.uid;

      // Only journey owner can update/delete
      allow update, delete: if isOwner(resource.data.driverId);
    }

    // Messages collection - private conversations
    match /messages/{messageId} {
      // Only participants can read messages
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);

      // Only sender can create messages
      allow create: if isAuthenticated()
        && isValidMessage()
        && request.auth.uid == request.resource.data.senderId;

      // No updates or deletes for messages (immutable)
      allow update, delete: if false;
    }

    // Users collection (if we add user profiles later)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Block all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}