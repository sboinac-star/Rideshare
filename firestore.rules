rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isBlocked() {
      return isAuthenticated()
        && request.auth.token.phone_number != null
        && exists(/databases/$(database)/documents/blockedPhones/$(request.auth.token.phone_number));
    }

    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidJourney() {
      let d = request.resource.data;
      return d.keys().hasAll(['driverName', 'from', 'to', 'departureTime', 'availableSeats', 'uid'])
        && d.driverName is string && d.driverName.size() > 0
        && d.from is string && d.from.size() > 0
        && d.to is string && d.to.size() > 0
        && d.availableSeats is int && d.availableSeats > 0 && d.availableSeats <= 8
        && d.uid == request.auth.uid;
    }

    function isCancelUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled'
        && resource.data.status == 'active';
    }

    function isCompleteUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'completed'
        && resource.data.status == 'active';
    }

    function isValidEdit() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['availableSeats', 'departureTime', 'returnTime'])
        && request.resource.data.availableSeats is int
        && request.resource.data.availableSeats > 0
        && request.resource.data.availableSeats <= 8
        && resource.data.status == 'active';
    }

    match /journeys/{journeyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidJourney() && !isBlocked();
      allow update: if isOwner() && (isCancelUpdate() || isCompleteUpdate() || isValidEdit());
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidRequest() {
      let d = request.resource.data;
      return d.keys().hasAll(['passengerName', 'from', 'to', 'departureTime', 'seatsNeeded', 'uid'])
        && d.passengerName is string && d.passengerName.size() > 0
        && d.from is string && d.from.size() > 0
        && d.to is string && d.to.size() > 0
        && d.seatsNeeded is int && d.seatsNeeded > 0 && d.seatsNeeded <= 8
        && d.uid == request.auth.uid;
    }

    function isCancelRequestUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'cancelled'
        && resource.data.status == 'active';
    }

    function isCompleteRequestUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'completed'
        && resource.data.status == 'active';
    }

    function isValidRequestEdit() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['seatsNeeded', 'departureTime', 'returnTime'])
        && request.resource.data.seatsNeeded is int
        && request.resource.data.seatsNeeded > 0
        && request.resource.data.seatsNeeded <= 8
        && resource.data.status == 'active';
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRequest() && !isBlocked();
      allow update: if isOwner() && (isCancelRequestUpdate() || isCompleteRequestUpdate() || isValidRequestEdit());
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isParticipant(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.participants;
    }

    function isValidNewChat() {
      let d = request.resource.data;
      return d.keys().hasAll(['participants', 'listingType', 'listingId', 'route', 'participantNames', 'lastMessage', 'updatedAt'])
        && d.participants is list
        && d.participants.size() == 2
        && request.auth.uid in d.participants
        && d.listingType in ['journey', 'request']
        && d.listingId is string && d.listingId.size() > 0
        && d.route is string && d.route.size() > 0
        && d.lastMessage == '';
    }

    function isChatMetadataUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);
    }

    match /chats/{chatId} {
      allow read: if resource == null ? isAuthenticated() : isParticipant(resource.data);
      allow create: if isAuthenticated() && isValidNewChat();
      allow update: if isParticipant(resource.data) && isChatMetadataUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow create: if isAuthenticated()
          && isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.keys().hasAll(['uid', 'senderName', 'text', 'createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if false;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['journeyId', 'reason'])
        && request.resource.data.journeyId is string
        && request.resource.data.reason is string;
      allow update, delete: if false;
    }

    match /blockedPhones/{phone} {
      allow read, write: if false;
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /fcmTokens/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /pageViews/{docId} { allow read, write: if false; }

    match /feedback/{docId} {
      allow read, delete: if false;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['text', 'createdAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
